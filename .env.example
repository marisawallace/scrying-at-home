# Copy this file to .env and update with your values

# Directory to search for export zip files
# If not set, defaults to the script directory
# Examples:
#   ZIP_SEARCH_DIR=/home/user/Downloads
#   ZIP_SEARCH_DIR=~/Downloads
ZIP_SEARCH_DIR=

# Override default data directories (optional)
# By default all data lives under data/ in the repo:
#   data/llm_data/         - organized chat archives
#   data/archived_exports/ - processed export zip files
#   data/local_views/      - generated Markdown/HTML views
#
# Uncomment and set these to use custom locations:
#
#LLM_DATA_DIR=~/clauding-at-home/data/llm_data
#ARCHIVED_EXPORTS_DIR=~/clauding-at-home/data/archived_exports
#LOCAL_VIEWS_DIR=~/clauding-at-home/data/local_views

# Claude Code session archives (set up automatically by
# `python3 migrations/002_setup_claude_code_archival.py`).
# Comma-separated hostname=path pairs. Each path is the archive root for
# JSONL transcripts captured on that machine. Multi-machine: each host adds
# its own entry, and search results are tagged with the originating hostname.
#
# In other words -- you can safely sync /home/code/clauding-at-home/data/ in
# Dropbox or MEGA and get all your history on all your machines.
#
#CLAUDE_CODE_SOURCES=laptop=/home/code/clauding-at-home/data/llm_data/claude-code/laptop,desktop=/home/code/clauding-at-home/data/llm_data/claude-code/desktop
